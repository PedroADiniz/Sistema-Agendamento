APP_NAME=Agendamento
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Banco de dados (host "mysql" = nome do serviço no docker-compose)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=agendamento
DB_USERNAME=agendamento
DB_PASSWORD=secret

# JWT (gerado com: php artisan jwt:secret)
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# CORS: origem do frontend Vite
FRONTEND_URL=http://localhost:5173
