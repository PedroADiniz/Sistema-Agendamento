# Variáveis usadas pelo docker-compose.yml (nível raiz)
# Copie este arquivo para .env e ajuste se necessário.
# Os valores abaixo já são os defaults usados pelo docker-compose.yml.

# Banco de dados
DB_DATABASE=agendamento
DB_USERNAME=agendamento
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# URL da API consumida pelo frontend (browser -> nginx)
VITE_API_URL=http://localhost:8000/api
